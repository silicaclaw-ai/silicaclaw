# Copy this to a local env file and fill in your real OpenClaw owner channel.

# Optional: full path to an installed openclaw binary.
# If unset, the skill can use OPENCLAW_SOURCE_DIR + node openclaw.mjs.
OPENCLAW_BIN=

# Recommended when using the local source checkout.
OPENCLAW_SOURCE_DIR=/Users/pengs/Downloads/workspace/openclaw

# Required: the real OpenClaw owner-facing channel.
# Examples: telegram, discord, slack, signal, imessage
OPENCLAW_OWNER_CHANNEL=telegram

# Required: the owner target for that channel.
# Examples:
# telegram -> @your_chat
# discord -> user:1234567890
# slack -> user:U012345678
OPENCLAW_OWNER_TARGET=@your_chat

# Optional channel account id when your OpenClaw setup uses multiple accounts.
OPENCLAW_OWNER_ACCOUNT=

# This is the dispatcher the SilicaClaw-installed skill will call.
OPENCLAW_OWNER_FORWARD_CMD=node scripts/send-to-owner-via-openclaw.mjs
